conc_order  = ['control','0.01uM','0.1uM','1uM','10uM','50uM','100uM','200uM']
conc_values = [0.001, 0.01, 0.1, 1, 10, 50, 100, 200]  # 0.001 = placeholder for control on log axis
conc_x_labels = ['Control','0.01','0.1','1','10','50','100','200']

cell_styles = {
    'A549':   {'color': '#2166AC', 'marker': 'o'},  # blue
    'NCI-H':  {'color': '#D6604D', 'marker': 's'},  # red
    'Calu-3': {'color': '#1A9641', 'marker': '^'},  # green
}

fig, axes = plt.subplots(1, 2, figsize=(13, 5.5), sharey=True)
fig.patch.set_facecolor('white')

genes = ['CB1', 'CB2']
gene_titles = ['Gene 1: CB1', 'Gene 2: CB2']

for ax, gene, gtitle in zip(axes, genes, gene_titles):
    ax.set_facecolor('white')
    ax.axhline(0, color='gray', linestyle='--', linewidth=0.9, alpha=0.7, zorder=1)

    for cl, style in cell_styles.items():
        means, sds = [], []
        for conc in conc_order:
            vals = data[cl][gene][conc]
            means.append(np.mean(vals))
            sds.append(np.std(vals, ddof=1))

        means = np.array(means)
        sds   = np.array(sds)

        ax.errorbar(conc_values, means, yerr=sds,
                    fmt=style['marker'] + '-',
                    color=style['color'],
                    markersize=6, linewidth=1.8,
                    capsize=3, capthick=1.2,
                    elinewidth=1.2,
                    label=cl, zorder=3)

    ax.set_xscale('log')
    ax.set_xlim(0.007, 300)
    ax.set_ylim(-3.2, 3.2)

    # Custom x tick labels
    ax.set_xticks(conc_values)
    ax.set_xticklabels(conc_x_labels, fontsize=8.5)
    ax.xaxis.set_minor_locator(ticker.NullLocator())

    ax.set_xlabel('Concentration of drug (µM)', fontsize=11)
    ax.set_title(gtitle, fontsize=11, fontstyle='italic', fontweight='bold')
    ax.grid(True, linestyle=':', alpha=0.35, color='gray')
    ax.spines[['top','right']].set_visible(False)

axes[0].set_ylabel('Log2 Fold Change\n(Relative to Control)', fontsize=11)
